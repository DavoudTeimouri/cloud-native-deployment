# Monitoring & Observability Configuration Template
# Generated by Wizard for {{ cluster_name }}

# =============================================================================
# Prometheus Configuration
# =============================================================================
prometheus_enabled: true
prometheus_version: "v2.48.0"
prometheus_namespace: monitoring
prometheus_retention: 30d
prometheus_retention_size: 50GB
prometheus_storage_class: "{{ cephfs_storage_class }}"
prometheus_pvc_size: 100Gi

# Prometheus External Endpoints (for HAProxy/MetalLB)
prometheus_external_ips:
{% for ip in prometheus_external_ips %}
  - "{{ ip }}"
{% endfor %}

# Alertmanager
alertmanager_enabled: true
alertmanager_version: "v0.26.0"
alertmanager_replicas: 3
alertmanager_storage_class: "{{ cephfs_storage_class }}"
alertmanager_pvc_size: 10Gi

# Alertmanager Config
alertmanager_config:
  global:
    resolve_timeout: 5m
  route:
    group_by: ['alertname']
    group_wait: 10s
    group_interval: 10m
    repeat_interval: 12h
    receiver: 'default'
  receivers:
    - name: 'default'
      email_configs:
        - to: 'admin@{{ domain_suffix }}'
          from: 'alertmanager@{{ domain_suffix }}'
          smarthost: 'smtp.{{ domain_suffix }}:587'
          auth_username: 'alertmanager@{{ domain_suffix }}'
          auth_password: '{{ smtp_password }}'

# Prometheus Rules (common alerts)
prometheus_rules:
  - alert: InstanceDown
    expr: up == 0
    for: 1m
    labels:
      severity: critical
    annotations:
      summary: "Instance {{ $labels.instance }} down"
      description: "{{ $labels.instance }} of job {{ $labels.job }} has been down for more than 1 minute."
  
  - alert: HighMemoryUsage
    expr: (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100 > 85
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: "High memory usage on {{ $labels.instance }}"
      description: "Memory usage on {{ $labels.instance }} is above 85%."

  - alert: HighCPUUsage
    expr: 100 - (avg by(instance) (irate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 85
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: "High CPU usage on {{ $labels.instance }}"
      description: "CPU usage on {{ $labels.instance }} is above 85%."

  - alert: DiskSpaceLow
    expr: (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: "Disk space low on {{ $labels.instance }}"
      description: "Disk space on {{ $labels.instance }} is below 10%."

# =============================================================================
# Grafana Configuration
# =============================================================================
grafana_enabled: true
grafana_version: "10.2.2"
grafana_namespace: monitoring
grafana_admin_user: admin
grafana_admin_password: "{{ grafana_admin_password }}"
grafana_domain: "grafana.{{ domain_suffix }}"
grafana_storage_class: "{{ cephfs_storage_class }}"
grafana_pvc_size: 10Gi

# Grafana Datasources
grafana_datasources:
  - name: Prometheus
    type: prometheus
    url: http://prometheus.monitoring.svc.cluster.local
    access: proxy
    isDefault: true
    editable: false
  - name: Loki
    type: loki
    url: http://loki.monitoring.svc.cluster.local
    access: proxy
    editable: false

# Grafana Dashboards (pre-provisioned)
grafana_dashboards:
  - name: kubernetes-cluster
    folder: Infrastructure
    source: https://grafana.com/api/dashboards/315/revisions/latest/download
  - name: node-exporter
    folder: Infrastructure
    source: https://grafana.com/api/dashboards/1860/revisions/latest/download
  - name: ceph-cluster
    folder: Storage
    source: https://grafana.com/api/dashboards/2842/revisions/latest/download
  - name: etcd
    folder: Infrastructure
    source: https://grafana.com/api/dashboards/3070/revisions/latest/download

# =============================================================================
# Loki Configuration
# =============================================================================
loki_enabled: true
loki_version: "2.9.2"
loki_namespace: monitoring
loki_storage_class: "{{ cephfs_storage_class }}"
loki_pvc_size: 50Gi
loki_retention: 30d

# Loki Component Replicas
loki_read_replicas: 2
loki_write_replicas: 2
loki_backend_replicas: 2

# Loki S3 Storage (using Ceph RGW)
loki_s3_enabled: true
loki_s3_endpoint: "https://{{ rgw_host_ip }}"
loki_s3_bucket: "{{ cluster_name }}-loki"
loki_s3_access_key: "{{ loki_s3_access_key }}"
loki_s3_secret_key: "{{ loki_s3_secret_key }}"
loki_s3_region: "us-east-1"
loki_s3_s3forcepathstyle: true

# =============================================================================
# Promtail Configuration
# =============================================================================
promtail_enabled: true
promtail_version: "2.9.2"
promtail_namespace: monitoring

# Promtail Config
promtail_config:
  clients:
    - url: http://loki.monitoring.svc.cluster.local/loki/api/v1/push
  positions:
    filename: /tmp/positions.yaml
  scrape_configs:
    - job_name: kubernetes-pods
      kubernetes_sd_configs:
        - role: pod
      relabel_configs:
        - source_labels: [__meta_kubernetes_pod_label_app]
          target_label: app
        - source_labels: [__meta_kubernetes_namespace]
          target_label: namespace
        - source_labels: [__meta_kubernetes_pod_name]
          target_label: pod

# =============================================================================
# Velero (Backup/DR) Configuration
# =============================================================================
velero_enabled: true
velero_version: "v1.12.1"
velero_namespace: velero
velero_storage_class: "{{ cephfs_storage_class }}"
velero_backup_pvc_size: 100Gi

# Velero S3 Storage (using Ceph RGW)
velero_s3_enabled: true
velero_s3_endpoint: "https://{{ rgw_host_ip }}"
velero_s3_bucket: "{{ cluster_name }}-velero"
velero_s3_region: "us-east-1"
velero_s3_access_key: "{{ velero_s3_access_key }}"
velero_s3_secret_key: "{{ velero_s3_secret_key }}"
velero_s3_s3forcepathstyle: true

# Velero Schedule
velero_schedule_enabled: true
velero_schedule_name: "daily-backup"
velero_schedule_cron: "0 2 * * *"  # Daily at 2 AM
velero_schedule_ttl: 720h  # 30 days

# Velero Resources to Include/Exclude
velero_include_namespaces:
  - "*"
velero_exclude_namespaces:
  - velero
  - monitoring
  - kube-system
  - kube-public
  - kube-node-lease

# Velero UI (Dashboard)
velero_ui_enabled: true
velero_ui_version: "v0.1.0"
velero_ui_domain: "velero.{{ domain_suffix }}"
velero_ui_ingress_class: nginx

# =============================================================================
# Operations Servers
# =============================================================================
ops_linux_ip: "{{ ops_linux_ip }}"
ops_windows_ip: "{{ ops_windows_ip }}"