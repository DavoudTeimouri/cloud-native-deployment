#!/bin/bash
# Deploy Monitoring Stack Script Template
# Generated by Wizard for {{ cluster_name }}
# Prometheus External IPs: {{ prometheus_external_ips }}
# Loki S3 Endpoint: {{ loki_s3_endpoint }}
# Velero S3 Endpoint: {{ velero_s3_endpoint }}

set -euo pipefail

# Configuration
CLUSTER_NAME="{{ cluster_name }}"
NAMESPACE="monitoring"
PROMETHEUS_EXTERNAL_IPS=({{ prometheus_external_ips }})
GRAFANA_ADMIN_PASSWORD="{{ grafana_admin_password }}"
LOKI_S3_ENDPOINT="{{ loki_s3_endpoint }}"
LOKI_S3_BUCKET="{{ loki_s3_bucket }}"
LOKI_S3_ACCESS_KEY="{{ loki_s3_access_key }}"
LOKI_S3_SECRET_KEY="{{ loki_s3_secret_key }}"
VELERO_S3_ENDPOINT="{{ velero_s3_endpoint }}"
VELERO_S3_BUCKET="{{ velero_s3_bucket }}"
VELERO_S3_ACCESS_KEY="{{ velero_s3_access_key }}"
VELERO_S3_SECRET_KEY="{{ velero_s3_secret_key }}"
OPS_LINUX_IP="{{ ops_linux_ip }}"

# Functions
deploy_prometheus() {
    echo "Deploying Prometheus..."
    
    ssh ${OPS_LINUX_IP} "cat > /tmp/prometheus-values.yaml << 'EOF'
prometheus:
  prometheusSpec:
    retention: 30d
    retentionSize: 50GB
    storageSpec:
      volumeClaimTemplate:
        spec:
          storageClassName: {{ cephfs_storage_class }}
          resources:
            requests:
              storage: 100Gi
    externalLabels:
      cluster: ${CLUSTER_NAME}
    serviceMonitorSelectorNilUsesHelmValues: false
    podMonitorSelectorNilUsesHelmValues: false

alertmanager:
  alertmanagerSpec:
    storage:
      volumeClaimTemplate:
        spec:
          storageClassName: {{ cephfs_storage_class }}
          resources:
            requests:
              storage: 10Gi
    config:
      global:
        resolve_timeout: 5m
      route:
        group_by: ['alertname']
        group_wait: 10s
        group_interval: 10m
        repeat_interval: 12h
        receiver: 'default'
      receivers:
        - name: 'default'
          email_configs:
            - to: 'admin@{{ domain_suffix }}'
              from: 'alertmanager@{{ domain_suffix }}'
              smarthost: 'smtp.{{ domain_suffix }}:587'
              auth_username: 'alertmanager@{{ domain_suffix }}'
              auth_password: '{{ smtp_password }}'

grafana:
  adminPassword: ${GRAFANA_ADMIN_PASSWORD}
  persistence:
    storageClassName: {{ cephfs_storage_class }}
    size: 10Gi
  datasources:
    datasources.yaml:
      apiVersion: 1
      datasources:
        - name: Prometheus
          type: prometheus
          url: http://prometheus-operated.monitoring.svc.cluster.local
          access: proxy
          isDefault: true
        - name: Loki
          type: loki
          url: http://loki.monitoring.svc.cluster.local
          access: proxy

kubePrometheusStack:
  fullnameOverride: kube-prometheus-stack
EOF"

    ssh ${OPS_LINUX_IP} "helm repo add prometheus-community https://prometheus-community.github.io/helm-charts && helm repo update"
    ssh ${OPS_LINUX_IP} "helm upgrade --install kube-prometheus-stack prometheus-community/kube-prometheus-stack -n ${NAMESPACE} --create-namespace -f /tmp/prometheus-values.yaml"
}

deploy_loki() {
    echo "Deploying Loki..."
    
    ssh ${OPS_LINUX_IP} "cat > /tmp/loki-values.yaml << 'EOF'
loki:
  auth_enabled: false
  commonConfig:
    replication_factor: 1
  storage:
    bucketNames:
      chunks: ${LOKI_S3_BUCKET}
      ruler: ${LOKI_S3_BUCKET}-ruler
    s3:
      endpoint: ${LOKI_S3_ENDPOINT}
      access_key: ${LOKI_S3_ACCESS_KEY}
      secret_key: ${LOKI_S3_SECRET_KEY}
      region: us-east-1
      s3forcepathstyle: true
  schemaConfig:
    configs:
      - from: 2024-01-01
        store: boltdb-shipper
        object_store: s3
        schema: v11
        index:
          prefix: index_
          period: 24h
  limits_config:
    retention_period: 30d
    ingestion_rate_mb: 10
    ingestion_burst_size_mb: 20

promtail:
  enabled: true
  config:
    clients:
      - url: http://loki.monitoring.svc.cluster.local/loki/api/v1/push

read:
  replicas: 2
write:
  replicas: 2
backend:
  replicas: 2
EOF"

    ssh ${OPS_LINUX_IP} "helm repo add grafana https://grafana.github.io/helm-charts && helm repo update"
    ssh ${OPS_LINUX_IP} "helm upgrade --install loki grafana/loki-stack -n ${NAMESPACE} -f /tmp/loki-values.yaml"
}

deploy_velero() {
    echo "Deploying Velero..."
    
    ssh ${OPS_LINUX_IP} "cat > /tmp/velero-values.yaml << 'EOF'
configuration:
  provider: aws
  backupStorageLocation:
    - name: default
      provider: aws
      bucket: ${VELERO_S3_BUCKET}
      config:
        region: us-east-1
        s3ForcePathStyle: "true"
        s3Url: ${VELERO_S3_ENDPOINT}
  volumeSnapshotLocation:
    - name: default
      provider: aws
      config:
        region: us-east-1
        s3ForcePathStyle: "true"
        s3Url: ${VELERO_S3_ENDPOINT}

credentials:
  secretContents:
    cloud: |
      [default]
      aws_access_key_id = ${VELERO_S3_ACCESS_KEY}
      aws_secret_access_key = ${VELERO_S3_SECRET_KEY}

initContainers:
  - name: velero-plugin-for-aws
    image: velero/velero-plugin-for-aws:v1.8.1
    volumeMounts:
      - mountPath: /target
        name: plugins

snapshotsEnabled: true
backupSyncTimeout: 300s

schedule:
  daily-backup:
    schedule: "0 2 * * *"
    template:
      ttl: 720h
      includedNamespaces:
        - "*"
      excludedNamespaces:
        - velero
        - monitoring
        - kube-system
        - kube-public
        - kube-node-lease
      labelSelector:
        matchLabels:
          velero.io/exclude-from-backup: "false"
EOF"

    ssh ${OPS_LINUX_IP} "helm repo add vmware-tanzu https://vmware-tanzu.github.io/helm-charts && helm repo update"
    ssh ${OPS_LINUX_IP} "helm upgrade --install velero vmware-tanzu/velero -n velero --create-namespace -f /tmp/velero-values.yaml"
}

# Main
deploy_prometheus
deploy_loki
deploy_velero

echo "Monitoring stack deployment complete!"