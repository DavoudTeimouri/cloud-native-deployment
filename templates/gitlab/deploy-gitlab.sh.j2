#!/bin/bash
# Deploy GitLab Script Template
# Generated by Wizard for {{ cluster_name }}
# GitLab Host: gitlab.{{ domain_suffix }}
# PostgreSQL Host: {{ gitlab_postgresql_host_ip }}
# Redis Host: {{ gitlab_redis_host_ip }}

set -euo pipefail

# Configuration
CLUSTER_NAME="{{ cluster_name }}"
DOMAIN_SUFFIX="{{ domain_suffix }}"
GITLAB_HOST="gitlab.${DOMAIN_SUFFIX}"
GITLAB_VERSION="{{ gitlab_version }}"
GITLAB_POSTGRESQL_HOST="{{ gitlab_postgresql_host_ip }}"
GITLAB_POSTGRESQL_PASSWORD="{{ gitlab_postgresql_password }}"
GITLAB_REDIS_HOST="{{ gitlab_redis_host_ip }}"
GITLAB_REDIS_PASSWORD="{{ gitlab_redis_password }}"
GITLAB_RUNNER_TOKEN="{{ gitlab_runner_token }}"
OPS_LINUX_IP="{{ ops_linux_ip }}"

# Functions
generate_gitlab_rb() {
    echo "Generating gitlab.rb..."
    
    ssh ${OPS_LINUX_IP} "cat > /tmp/gitlab.rb << 'EOF'
external_url 'https://${GITLAB_HOST}'

# Database
postgresql['enable'] = false
gitlab_rails['db_adapter'] = 'postgresql'
gitlab_rails['db_encoding'] = 'utf8'
gitlab_rails['db_host'] = '${GITLAB_POSTGRESQL_HOST}'
gitlab_rails['db_port'] = 5432
gitlab_rails['db_database'] = 'gitlab'
gitlab_rails['db_username'] = 'gitlab'
gitlab_rails['db_password'] = '${GITLAB_POSTGRESQL_PASSWORD}'

# Redis
redis['enable'] = false
gitlab_rails['redis_host'] = '${GITLAB_REDIS_HOST}'
gitlab_rails['redis_port'] = 6379
gitlab_rails['redis_password'] = '${GITLAB_REDIS_PASSWORD}'

# Registry (using Ceph RGW/MinIO)
registry['enable'] = true
registry_external_url 'https://registry.${DOMAIN_SUFFIX}'
gitlab_rails['registry_enabled'] = true
gitlab_rails['registry_host'] = 'registry.${DOMAIN_SUFFIX}'
gitlab_rails['registry_port'] = 443
gitlab_rails['registry_api_url'] = 'https://registry.${DOMAIN_SUFFIX}/api/v2'
gitlab_rails['registry_key_path'] = '/var/opt/gitlab/gitlab-rails/etc/registry-key.key'
gitlab_rails['registry_issuer'] = 'gitlab-issuer'

# Object Storage (Ceph RGW/MinIO)
gitlab_rails['object_store'] = {
  enabled: true,
  proxy_download: true,
  connection: {
    provider: 'AWS',
    region: 'us-east-1',
    endpoint: 'https://{{ rgw_host_ip }}',
    access_key_id: '{{ gitlab_s3_access_key }}',
    secret_access_key: '{{ gitlab_s3_secret_key }}',
    path_style: true
  },
  objects: {
    artifacts: { bucket: '${CLUSTER_NAME}-artifacts' },
    lfs: { bucket: '${CLUSTER_NAME}-lfs' },
    uploads: { bucket: '${CLUSTER_NAME}-uploads' },
    packages: { bucket: '${CLUSTER_NAME}-packages' },
    dependency_proxy: { bucket: '${CLUSTER_NAME}-dependency-proxy' },
    terraform_state: { bucket: '${CLUSTER_NAME}-terraform-state' },
    pages: { bucket: '${CLUSTER_NAME}-pages' }
  }
}

# Backup to S3 (Ceph RGW/MinIO)
gitlab_rails['backup_upload_connection'] = {
  provider: 'AWS',
  region: 'us-east-1',
  endpoint: 'https://{{ rgw_host_ip }}',
  access_key_id: '{{ gitlab_s3_access_key }}',
  secret_access_key: '{{ gitlab_s3_secret_key }}',
  path_style: true
}
gitlab_rails['backup_upload_remote_directory'] = '${CLUSTER_NAME}-gitlab-backups'
gitlab_rails['backup_keep_time'] = 2592000  # 30 days

# Monitoring
prometheus['enable'] = true
node_exporter['enable'] = true
redis_exporter['enable'] = true
postgres_exporter['enable'] = true

# GitLab Pages
pages_external_url 'https://pages.${DOMAIN_SUFFIX}'
gitlab_pages['enable'] = true
gitlab_pages['access_control'] = true

# TLS
nginx['ssl_certificate'] = '/etc/gitlab/ssl/${GITLAB_HOST}.crt'
nginx['ssl_certificate_key'] = '/etc/gitlab/ssl/${GITLAB_HOST}.key'
registry_nginx['ssl_certificate'] = '/etc/gitlab/ssl/registry.${DOMAIN_SUFFIX}.crt'
registry_nginx['ssl_certificate_key'] = '/etc/gitlab/ssl/registry.${DOMAIN_SUFFIX}.key'
pages_nginx['ssl_certificate'] = '/etc/gitlab/ssl/pages.${DOMAIN_SUFFIX}.crt'
pages_nginx['ssl_certificate_key'] = '/etc/gitlab/ssl/pages.${DOMAIN_SUFFIX}.key'

# Performance
puma['worker_processes'] = 4
sidekiq['max_concurrency'] = 25
gitaly['configuration'] = {
  concurrency: [{ 'rpc': '/gitaly.SmartHTTPService/PostReceivePack', 'max_per_repo': 3 }]
}
EOF"
}

deploy_gitlab() {
    echo "Deploying GitLab..."
    
    # Copy config
    ssh ${OPS_LINUX_IP} "mkdir -p /etc/gitlab"
    scp /tmp/gitlab.rb ${OPS_LINUX_IP}:/etc/gitlab/gitlab.rb
    
    # Install GitLab
    ssh ${OPS_LINUX_IP} "
        curl -sS https://packages.gitlab.com/install/repositories/gitlab/gitlab-ee/script.deb.sh | bash &&
        apt-get install -y gitlab-ee=${GITLAB_VERSION}-ee.0
    "
    
    # Reconfigure
    ssh ${OPS_LINUX_IP} "gitlab-ctl reconfigure"
}

configure_runner() {
    echo "Configuring GitLab Runner..."
    
    ssh ${OPS_LINUX_IP} "
        curl -L https://packages.gitlab.com/install/repositories/runner/gitlab-runner/script.deb.sh | bash &&
        apt-get install -y gitlab-runner
    "
    
    ssh ${OPS_LINUX_IP} "
        gitlab-runner register \
          --non-interactive \
          --url 'https://${GITLAB_HOST}' \
          --registration-token '${GITLAB_RUNNER_TOKEN}' \
          --executor 'kubernetes' \
          --kubernetes-namespace 'gitlab-runners' \
          --tag-list 'k8s,linux,docker' \
          --run-untagged='true' \
          --locked='false'
    "
}

# Main
generate_gitlab_rb
deploy_gitlab
configure_runner

echo "GitLab deployment complete!"