# GitLab Configuration Template
# Generated by Wizard for {{ cluster_name }}

# =============================================================================
# GitLab Configuration
# =============================================================================
gitlab_enabled: true
gitlab_version: "16.11.0"
gitlab_namespace: gitlab
gitlab_host: "gitlab.{{ domain_suffix }}"
gitlab_external_url: "https://gitlab.{{ domain_suffix }}"

# GitLab Database (PostgreSQL)
gitlab_postgresql_enabled: true
gitlab_postgresql_host: "{{ gitlab_postgresql_host_ip }}"
gitlab_postgresql_port: 5432
gitlab_postgresql_database: gitlab
gitlab_postgresql_username: gitlab
gitlab_postgresql_password: "{{ gitlab_postgresql_password }}"

# GitLab Redis
gitlab_redis_enabled: true
gitlab_redis_host: "{{ gitlab_redis_host_ip }}"
gitlab_redis_port: 6379
gitlab_redis_password: "{{ gitlab_redis_password }}"

# GitLab Registry
gitlab_registry_enabled: true
gitlab_registry_host: "registry.{{ domain_suffix }}"
gitlab_registry_port: 443
gitlab_registry_storage: "{{ ceph_rgw_bucket }}"

# GitLab Runner
gitlab_runner_enabled: true
gitlab_runner_registration_token: "{{ gitlab_runner_token }}"
gitlab_runner_tags: "k8s,linux,docker"
gitlab_runner_executor: kubernetes

# GitLab Object Storage (Ceph RGW)
gitlab_object_storage_enabled: true
gitlab_object_storage_connection:
  provider: AWS
  region: us-east-1
  endpoint: "https://{{ rgw_host_ip }}"
  access_key_id: "{{ gitlab_s3_access_key }}"
  secret_access_key: "{{ gitlab_s3_secret_key }}"
  path_style: true

# =============================================================================
# GitLab CI/CD Integration
# =============================================================================
gitlab_ci_k8s_integration: true
gitlab_ci_k8s_cluster_name: "{{ cluster_name }}"
gitlab_ci_k8s_api_url: "https://{{ master_ips[0] }}:6443"
gitlab_ci_k8s_ca_cert: "/etc/gitlab/ssl/k8s-ca.crt"
gitlab_ci_k8s_token: "{{ gitlab_k8s_service_account_token }}"

# =============================================================================
# GitLab Backup (Velero integration)
# =============================================================================
gitlab_backup_enabled: true
gitlab_backup_schedule: "0 3 * * *"  # Daily at 3 AM
gitlab_backup_retention: 30
gitlab_backup_storage: s3
gitlab_backup_s3_bucket: "{{ cluster_name }}-gitlab-backups"
gitlab_backup_s3_endpoint: "https://{{ rgw_host_ip }}"

# =============================================================================
# Operations Servers
# =============================================================================
ops_linux_ip: "{{ ops_linux_ip }}"
ops_windows_ip: "{{ ops_windows_ip }}"