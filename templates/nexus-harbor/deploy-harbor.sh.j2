# Deploy Harbor Script Template
# Generated by Wizard for {{ cluster_name }}

#!/bin/bash
# Harbor Registry Deployment
# Customized for cluster: {{ cluster_name }}
# Harbor Host IP: {{ harbor_host_ip }}

set -euo pipefail

# Configuration
HARBOR_HOST="{{ harbor_host_ip }}"
HARBOR_VERSION="{{ harbor_version }}"
HARBOR_DATA_DIR="{{ harbor_data_dir }}"
HARBOR_ADMIN_PASSWORD="{{ harbor_admin_password }}"
HARBOR_DB_PASSWORD="{{ harbor_database_password }}"
HARBOR_REDIS_PASSWORD="{{ harbor_redis_password }}"

# External URLs
export HARBOR_URL="https://${HARBOR_HOST}"
export HARBOR_CORE_URL="${HARBOR_URL}/api/v2.0"
export HARBOR_NOTARY_URL="${HARBOR_URL}:4443"

# Harbor projects to create
HARBOR_PROJECTS="{{ harbor_projects }}"

# Functions
generate_harbor_yaml() {
    echo "Generating harbor.yaml..."
    
    ssh ${OPS_LINUX_IP} "cat > ${HARBOR_DATA_DIR}/harbor.yml << 'HARBORYAML'
hostname: ${HARBOR_HOST}
http:
  port: 80
https:
  port: 443
  certificate: /data/cert/server.crt
  private_key: /data/cert/server.key
internal_tls:
  enabled: false
harbor:
  admin_password: '${HARBOR_ADMIN_PASSWORD}'
database:
  password: '${HARBOR_DB_PASSWORD}'
clair:
  updaters_interval: 12h
  whitespace_allowed: false
notary:
  password: '${HARBOR_DB_PASSWORD}'
redis:
  password: '${HARBOR_REDIS_PASSWORD}'
registry:
  storage_provider: filesystem
  file_system:
    rootdirectory: /data/registry
trivy:
  ignore_unfixed: false
  skip_db_update: true
HARBORYAML"
}

deploy_harbor() {
    echo "Deploying Harbor Registry to ${HARBOR_HOST}..."
    
    # Create directories
    ssh ${OPS_LINUX_IP} "mkdir -p ${HARBOR_DATA_DIR}/{data,cert}"
    
    # Copy Harbor installer
    scp harbor-offline-installer-${HARBOR_VERSION}.tgz ${OPS_LINUX_IP}:${HARBOR_DATA_DIR}/
    
    # Install
    ssh ${OPS_LINUX_IP} "
        cd ${HARBOR_DATA_DIR} && \
        tar -xzf harbor-offline-installer-${HARBOR_VERSION}.tgz && \
        cd harbor && \
        ./install.sh
    "
}

create_projects() {
    echo "Creating Harbor projects..."
    
    # Wait for Harbor to be ready
    until curl -skf https://${HARBOR_HOST}/api/v2.0/projects >/dev/null 2>&1; do
        echo "Waiting for Harbor..."
        sleep 5
    done
    
    # Create projects via API
    for project in ${HARBOR_PROJECTS//,/ }; do
        curl -sk -X POST \
            -H "Content-Type: application/json" \
            -u "admin:${HARBOR_ADMIN_PASSWORD}" \
            -d "{\"project_name\":\"${project}\",\"public\":false}" \
            https://${HARBOR_HOST}/api/v2.0/projects
    done
}

configure_replication() {
    echo "Configuring replication targets..."
    # Setup replication with other registries if needed
}

# Main
generate_harbor_yaml
deploy_harbor
create_projects
echo "Harbor deployment complete!"