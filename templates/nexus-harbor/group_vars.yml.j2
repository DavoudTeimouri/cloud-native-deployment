# Nexus + Harbor Deployment Template
# Generated by Wizard for {{ cluster_name }}

# =============================================================================
# Nexus Repository Manager
# =============================================================================
nexus_host: "{{ nexus_host_ip }}"
nexus_port: 8081
nexus_docker_port: 8082
nexus_helm_port: 8083
nexus_pypi_port: 8084
nexus_yum_port: 8085
nexus_nuget_port: 8086
nexus_raw_port: 8087
nexus_admin_user: admin
nexus_admin_password: "{{ nexus_admin_password }}"

# Nexus URLs (used by other components)
nexus_url: "http://{{ nexus_host_ip }}:{{ nexus_port }}"
nexus_apt_repo: "http://{{ nexus_host_ip }}:{{ nexus_port }}/repository/apt-ubuntu-hosted/"
nexus_pypi_repo: "http://{{ nexus_host_ip }}:{{ nexus_port }}/repository/pypi-group/simple"
nexus_helm_repo: "http://{{ nexus_host_ip }}:{{ nexus_port }}/repository/helm-hosted/"
nexus_yum_repo: "http://{{ nexus_host_ip }}:{{ nexus_port }}/repository/yum-hosted-ceph/"
nexus_docker_repo: "{{ nexus_host_ip }}:{{ nexus_docker_port }}"

# Nexus data directories
nexus_data_dir: /opt/nexus/data
nexus_backup_dir: /opt/nexus/backups

# =============================================================================
# Harbor Registry
# =============================================================================
harbor_host: "{{ harbor_host_ip }}"
harbor_port: 443
harbor_admin_user: admin
harbor_admin_password: "{{ harbor_admin_password }}"
harbor_database_password: "{{ harbor_database_password }}"
harbor_redis_password: "{{ harbor_redis_password }}"

# Harbor URLs
harbor_url: "https://{{ harbor_host_ip }}"
harbor_core_url: "https://{{ harbor_host_ip }}/api/v2.0"
harbor_notary_url: "https://{{ harbor_host_ip }}:4443"

# Harbor projects (pre-created by wizard)
harbor_projects:
  - name: k8s-images
    public: false
  - name: ceph-images
    public: false
  - name: monitoring-images
    public: false
  - name: platform-images
    public: false
  - name: os-images
    public: false

# Harbor data directories
harbor_data_dir: /opt/harbor/data
harbor_registry_dir: /opt/harbor/registry
harbor_database_dir: /opt/harbor/database
harbor_redis_dir: /opt/harbor/redis
harbor_log_dir: /var/log/harbor

# =============================================================================
# Ops Server IPs (for script execution)
# =============================================================================
ops_linux_ip: "{{ ops_linux_ip }}"
ops_windows_ip: "{{ ops_windows_ip }}"

# =============================================================================
# Network Configuration
# =============================================================================
domain_suffix: "{{ domain_suffix }}"
nexus_fqdn: "nexus.{{ domain_suffix }}"
harbor_fqdn: "harbor.{{ domain_suffix }}"