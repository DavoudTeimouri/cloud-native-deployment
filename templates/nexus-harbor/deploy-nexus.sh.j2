#!/bin/bash
# Nexus Repository Manager Deployment
# Customized for cluster: {{ cluster_name }}
# Nexus Host IP: {{ nexus_host_ip }}
# Nexus Ports: {{ nexus_ports }}

set -euo pipefail

# Configuration
NEXUS_HOST="{{ nexus_host_ip }}"
NEXUS_VERSION="{{ nexus_version }}"
NEXUS_DATA_DIR="{{ nexus_data_dir }}"
NEXUS_ADMIN_PASSWORD="{{ nexus_admin_password }}"

# Export variables for scripts
export NEXUS_URL="http://${NEXUS_HOST}:{{ nexus_http_port }}"
export NEXUS_DOCKER_URL="${NEXUS_HOST}:{{ nexus_docker_port }}"
export NEXUS_HELM_URL="http://${NEXUS_HOST}:{{ nexus_helm_port }}/repository/helm-hosted/"
export NEXUS_PYPI_URL="http://${NEXUS_HOST}:{{ nexus_pypi_port }}/repository/pypi-group/simple"

# Functions
check_prerequisites() {
    echo "Checking prerequisites..."
    command -v docker >/dev/null 2>&1 || { echo "Docker required"; exit 1; }
    command -v curl >/dev/null 2>&1 || { echo "curl required"; exit 1; }
}

deploy_nexus() {
    echo "Deploying Nexus Repository Manager to ${NEXUS_HOST}..."
    
    # Create directories
    ssh ${OPS_LINUX_IP} "mkdir -p ${NEXUS_DATA_DIR}"
    
    # Generate docker-compose.yml
    ssh ${OPS_LINUX_IP} "cat > ${NEXUS_DATA_DIR}/docker-compose.yml << 'COMPOSE'
version: '3.8'
services:
  nexus:
    image: sonatype/nexus3:${NEXUS_VERSION}
    container_name: nexus
    restart: unless-stopped
    ports:
      - {{ nexus_http_port }}:8081
      - {{ nexus_docker_port }}:8082
      - {{ nexus_helm_port }}:8083
      - {{ nexus_pypi_port }}:8084
      - {{ nexus_yum_port }}:8085
    volumes:
      - nexus-data:/nexus-data
      - ./nexus-config:/opt/sonatype/nexus/nexus-config
    environment:
      - INSTALL4J_ADD_VM_PARAMS=-Xms2g -Xmx4g -XX:MaxDirectMemorySize=4g

volumes:
  nexus-data:
COMPOSE"
    
    # Start Nexus
    ssh ${OPS_LINUX_IP} "cd ${NEXUS_DATA_DIR} && docker-compose up -d"
    
    echo "Nexus deployment initiated. Wait 2-3 minutes for startup."
}

