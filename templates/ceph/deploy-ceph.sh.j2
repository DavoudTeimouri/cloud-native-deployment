#!/bin/bash
# Deploy Ceph Bare Metal Script Template
# Generated by Wizard for {{ cluster_name }}
# Ceph Monitor IPs: {{ ceph_mon_ips }}
# Ceph OSD IPs: {{ ceph_osd_ips }}
# Ceph Public CIDR: {{ ceph_public_cidr }}
# Ceph Cluster CIDR: {{ ceph_cluster_cidr }}

set -euo pipefail

# Configuration
CEPH_MON_IPS=({{ ceph_mon_ips }})
CEPH_OSD_IPS=({{ ceph_osd_ips }})
CEPH_FSID="{{ ceph_fsid }}"
CEPH_PUBLIC_NETWORK="{{ ceph_public_cidr }}"
CEPH_CLUSTER_NETWORK="{{ ceph_cluster_cidr }}"
CEPH_CLUSTER_NAME="{{ cluster_name }}-ceph"
OPS_LINUX_IP="{{ ops_linux_ip }}"

# Functions
generate_ceph_conf() {
    echo "Generating ceph.conf..."
    
    ssh ${OPS_LINUX_IP} "cat > /tmp/ceph.conf << 'EOF'
[global]
fsid = ${CEPH_FSID}
mon_initial_members = $(for i in "${!CEPH_MON_IPS[@]}"; do echo -n "ceph-mon-$((i+1))"; [ $i -lt $((${#CEPH_MON_IPS[@]}-1)) ] && echo -n ", "; done)
mon_host = $(for ip in "${CEPH_MON_IPS[@]}"; do echo -n "$ip"; [ "$ip" != "${CEPH_MON_IPS[-1]}" ] && echo -n ", "; done)
public_network = ${CEPH_PUBLIC_NETWORK}
cluster_network = ${CEPH_CLUSTER_NETWORK}
auth_cluster_required = cephx
auth_service_required = cephx
auth_client_required = cephx
osd_pool_default_size = 3
osd_pool_default_min_size = 2
osd_crush_chooseleaf_type = 1
EOF"
}

deploy_monitors() {
    echo "Deploying Ceph Monitors..."
    
    for i in "${!CEPH_MON_IPS[@]}"; do
        mon_ip="${CEPH_MON_IPS[i]}"
        mon_name="ceph-mon-$((i+1))"
        
        echo "Setting up monitor $mon_name at $mon_ip..."
        
        ssh ${OPS_LINUX_IP} "ssh $mon_ip 'mkdir -p /etc/ceph /var/lib/ceph/mon/$mon_name'"
        scp /tmp/ceph.conf ${OPS_LINUX_IP}:$mon_ip:/etc/ceph/ceph.conf
        
        # Create keyring
        ssh ${OPS_LINUX_IP} "ssh $mon_ip 'ceph-authtool --create-keyring /tmp/ceph.mon.keyring --gen-key -n mon. --cap mon \"allow *\"'"
        
        # Create monitor map
        ssh ${OPS_LINUX_IP} "ssh $mon_ip 'monmaptool --create --add $mon_name $mon_ip --fsid $CEPH_FSID /tmp/monmap'"
        
        # Initialize monitor
        ssh ${OPS_LINUX_IP} "ssh $mon_ip 'ceph-mon --mkfs -i $mon_name --monmap /tmp/monmap --keyring /tmp/ceph.mon.keyring'"
        
        # Start monitor
        ssh ${OPS_LINUX_IP} "ssh $mon_ip 'systemctl enable ceph-mon@$mon_name && systemctl start ceph-mon@$mon_name'"
    done
}

deploy_osds() {
    echo "Deploying Ceph OSDs..."
    
    for i in "${!CEPH_OSD_IPS[@]}"; do
        osd_ip="${CEPH_OSD_IPS[i]}"
        osd_id=$((i+1))
        
        echo "Setting up OSD $osd_id at $osd_ip..."
        
        ssh ${OPS_LINUX_IP} "ssh $osd_ip 'mkdir -p /etc/ceph /var/lib/ceph/osd/ceph-$osd_id'"
        scp /tmp/ceph.conf ${OPS_LINUX_IP}:$osd_ip:/etc/ceph/ceph.conf
        
        # Create OSD keyring
        ssh ${OPS_LINUX_IP} "ssh $osd_ip 'ceph-authtool --create-keyring /var/lib/ceph/osd/ceph-$osd_id/keyring --gen-key -n osd.$osd_id --cap osd \"allow *\" --cap mon \"allow profile osd\"'"
        
        # Register OSD
        ssh ${OPS_LINUX_IP} "ssh $osd_ip 'ceph osd create $osd_id'"
        
        # Start OSD
        ssh ${OPS_LINUX_IP} "ssh $osd_ip 'systemctl enable ceph-osd@$osd_id && systemctl start ceph-osd@$osd_id'"
    done
}

create_pools() {
    echo "Creating Ceph pools..."
    
    # Wait for cluster to be healthy
    ssh ${OPS_LINUX_IP} "ssh ${CEPH_MON_IPS[0]} 'ceph -s'"
    
    # CephFS pools
    ssh ${OPS_LINUX_IP} "ssh ${CEPH_MON_IPS[0]} 'ceph osd pool create {{ cluster_name }}_cephfs_data 128 128'"
    ssh ${OPS_LINUX_IP} "ssh ${CEPH_MON_IPS[0]} 'ceph osd pool create {{ cluster_name }}_cephfs_metadata 32 32'"
    ssh ${OPS_LINUX_IP} "ssh ${CEPH_MON_IPS[0]} 'ceph fs new {{ cluster_name }}-cephfs {{ cluster_name }}_cephfs_metadata {{ cluster_name }}_cephfs_data'"
    
    # RBD pool
    ssh ${OPS_LINUX_IP} "ssh ${CEPH_MON_IPS[0]} 'ceph osd pool create {{ cluster_name }}_rbd 128 128'"
    ssh ${OPS_LINUX_IP} "ssh ${CEPH_MON_IPS[0]} 'rbd pool init {{ cluster_name }}_rbd'"
    
    # RGW pools
    ssh ${OPS_LINUX_IP} "ssh ${CEPH_MON_IPS[0]} 'ceph osd pool create {{ cluster_name }}.rgw.buckets.index 32 32'"
    ssh ${OPS_LINUX_IP} "ssh ${CEPH_MON_IPS[0]} 'ceph osd pool create {{ cluster_name }}.rgw.buckets.data 128 128'"
}

# Main
generate_ceph_conf
deploy_monitors
deploy_osds
create_pools
echo "Ceph bare metal deployment complete!"