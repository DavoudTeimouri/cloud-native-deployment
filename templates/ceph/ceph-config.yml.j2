# Ceph Deployment Configuration Template
# Generated by Wizard for {{ cluster_name }}

# =============================================================================
# Ceph Monitor Nodes
# =============================================================================
ceph_mon_ips:
{% for ip in ceph_mon_ips %}
  - "{{ ip }}"
{% endfor %}

# =============================================================================
# Ceph OSD Nodes
# =============================================================================
ceph_osd_ips:
{% for ip in ceph_osd_ips %}
  - "{{ ip }}"
{% endfor %}

# =============================================================================
# Ceph Configuration
# =============================================================================
ceph_cluster_name: "{{ cluster_name }}-ceph"
ceph_fsid: "{{ ceph_fsid }}"

# Network
ceph_public_network: "{{ ceph_public_cidr }}"
ceph_cluster_network: "{{ ceph_cluster_cidr }}"

# Monitor
ceph_mon_initial_members:
{% for i in range(ceph_mon_ips|length) %}
  - "ceph-mon-{{ i+1 }}"
{% endfor %}

ceph_mon_host: "{{ ceph_mon_ips | join(',') }}"

# OSD Configuration
osd_objectstore: bluestore
osd_bluestore_block_db_size: 100GB
osd_bluestore_block_wal_size: 50GB

# =============================================================================
# CephFS Configuration
# =============================================================================
cephfs_name: "{{ cluster_name }}-cephfs"
cephfs_data_pool: "{{ cluster_name }}_cephfs_data"
cephfs_metadata_pool: "{{ cluster_name }}_cephfs_metadata"

# =============================================================================
# RBD Configuration
# =============================================================================
rbd_pool_name: "{{ cluster_name }}_rbd"
rbd_pool_pg_num: 128
rbd_pool_pgp_num: 128

# =============================================================================
# RGW (Object Gateway) Configuration
# =============================================================================
rgw_host: "{{ rgw_host_ip }}"
rgw_port: 80
rgw_dns_name: "rgw.{{ domain_suffix }}"
rgw_realm: "{{ cluster_name }}-realm"
rgw_zonegroup: "{{ cluster_name }}-zonegroup"
rgw_zone: "{{ cluster_name }}-zone"

# RGW Placement
rgw_placement_pools:
  - name: "{{ cluster_name }}.rgw.buckets.index"
    pg_num: 32
  - name: "{{ cluster_name }}.rgw.buckets.data"
    pg_num: 128

# =============================================================================
# Client Configuration (for CSI, K8s, etc.)
# =============================================================================
ceph_client_admin_keyring: /etc/ceph/ceph.client.admin.keyring
ceph_client_kube_keyring: /etc/ceph/ceph.client.kubernetes.keyring

# CSI RBD Plugin
csi_rbd_provisioner_secret_name: "csi-rbd-secret"
csi_rbd_provisioner_secret_namespace: "kube-system"
csi_rbd_node_secret_name: "csi-rbd-node-secret"
csi_rbd_node_secret_namespace: "kube-system"

# CSI CephFS Plugin
csi_cephfs_provisioner_secret_name: "csi-cephfs-secret"
csi_cephfs_provisioner_secret_namespace: "kube-system"
csi_cephfs_node_secret_name: "csi-cephfs-node-secret"
csi_cephfs_node_secret_namespace: "kube-system"

# =============================================================================
# Harbor Integration (for image storage)
# =============================================================================
harbor_url: "https://{{ harbor_host_ip }}"
harbor_registry_dir: /opt/harbor/registry
ceph_rgw_for_harbor: true

# =============================================================================
# Monitoring Integration
# =============================================================================
prometheus_ceph_exporter_port: 9283
ceph_exporter_targets:
{% for ip in ceph_mon_ips %}
  - "{{ ip }}:{{ prometheus_ceph_exporter_port }}"
{% endfor %}

# =============================================================================
# Operations Servers
# =============================================================================
ops_linux_ip: "{{ ops_linux_ip }}"
ops_windows_ip: "{{ ops_windows_ip }}"