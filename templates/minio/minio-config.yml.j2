# MinIO Object Storage Configuration Template
# Generated by Wizard for {{ cluster_name }}

# =============================================================================
# MinIO Configuration (Alternative to Ceph RGW)
# =============================================================================
minio_enabled: {{ minio_enabled | lower }}
minio_version: "RELEASE.2024-05-28T17-19-04Z"
minio_namespace: minio

# MinIO Endpoints
minio_api_host: "{{ minio_api_host_ip }}"
minio_console_host: "{{ minio_console_host_ip }}"
minio_api_port: 9000
minio_console_port: 9001

# MinIO Credentials
minio_root_user: "{{ minio_root_user }}"
minio_root_password: "{{ minio_root_password }}"

# MinIO External URLs
minio_api_url: "https://{{ minio_api_host_ip }}:9000"
minio_console_url: "https://{{ minio_console_host_ip }}:9001"

# MinIO Buckets (pre-created)
minio_buckets:
  - name: "{{ cluster_name }}-loki"
    versioning: true
  - name: "{{ cluster_name }}-velero"
    versioning: true
  - name: "{{ cluster_name }}-gitlab-backups"
    versioning: true
  - name: "{{ cluster_name }}-harbor"
    versioning: true
  - name: "{{ cluster_name }}-artifacts"
    versioning: true

# MinIO Replication (for multi-site)
minio_replication_enabled: {{ minio_replication_enabled | lower }}
minio_replication_targets:
  # Example for DR site
  # - alias: dr-site
  #   endpoint: "https://minio-dr.other-site.internal:9000"
  #   access_key: "{{ dr_minio_access_key }}"
  #   secret_key: "{{ dr_minio_secret_key }}"
  #   bucket: "{{ cluster_name }}-velero"

# MinIO Policies
minio_policies:
  - name: "readwrite-{{ cluster_name }}-loki"
    bucket: "{{ cluster_name }}-loki"
    actions:
      - "s3:GetObject"
      - "s3:PutObject"
      - "s3:DeleteObject"
      - "s3:ListBucket"

# MinIO Users
minio_users:
  - access_key: "{{ loki_s3_access_key }}"
    secret_key: "{{ loki_s3_secret_key }}"
    policy: "readwrite-{{ cluster_name }}-loki"
  - access_key: "{{ velero_s3_access_key }}"
    secret_key: "{{ velero_s3_secret_key }}"
    policy: "readwrite-{{ cluster_name }}-velero"

# MinIO Storage Class
minio_storage_class: "{{ cephfs_storage_class }}"
minio_pvc_size: 200Gi
minio_replicas: 4

# =============================================================================
# MinIO Integration with Other Components
# =============================================================================
# Loki
loki_s3_endpoint: "https://{{ minio_api_host_ip }}:9000"
loki_s3_bucket: "{{ cluster_name }}-loki"
loki_s3_access_key: "{{ loki_s3_access_key }}"
loki_s3_secret_key: "{{ loki_s3_secret_key }}"

# Velero
velero_s3_endpoint: "https://{{ minio_api_host_ip }}:9000"
velero_s3_bucket: "{{ cluster_name }}-velero"
velero_s3_access_key: "{{ velero_s3_access_key }}"
velero_s3_secret_key: "{{ velero_s3_secret_key }}"

# Harbor (if using MinIO for storage)
harbor_s3_endpoint: "https://{{ minio_api_host_ip }}:9000"
harbor_s3_bucket: "{{ cluster_name }}-harbor"
harbor_s3_access_key: "{{ harbor_s3_access_key }}"
harbor_s3_secret_key: "{{ harbor_s3_secret_key }}"

# GitLab (if using MinIO for artifacts/LFS)
gitlab_s3_endpoint: "https://{{ minio_api_host_ip }}:9000"
gitlab_s3_bucket: "{{ cluster_name }}-gitlab-backups"
gitlab_s3_access_key: "{{ gitlab_s3_access_key }}"
gitlab_s3_secret_key: "{{ gitlab_s3_secret_key }}"

# =============================================================================
# Operations Servers
# =============================================================================
ops_linux_ip: "{{ ops_linux_ip }}"
ops_windows_ip: "{{ ops_windows_ip }}"