# Networking Configuration Template
# Generated by Wizard for {{ cluster_name }}

# =============================================================================
# MetalLB Configuration (Application Cluster Only)
# =============================================================================
metallb_enabled: {{ metallb_enabled | lower }}
metallb_ip_pool_start: "{{ metallb_start_ip }}"
metallb_ip_pool_end: "{{ metallb_end_ip }}"
metallb_pool_name: "{{ cluster_name }}-pool"
metallb_protocol: layer2

# MetalLB L2 Advertisement
metallb_l2_advertisement:
  - name: "{{ cluster_name }}-l2-advertisement"
    ip_address_pools:
      - "{{ cluster_name }}-pool"

# MetalLB BGP Configuration (if using BGP mode)
metallb_bgp_peers: []
# Example:
# metallb_bgp_peers:
#   - name: "router-1"
#     peer_address: "10.0.0.1"
#     peer_asn: 65001
#     my_asn: 65002

# =============================================================================
# NGINX Ingress Controller Configuration
# =============================================================================
nginx_ingress_enabled: true
nginx_ingress_controller_host_network: true
nginx_ingress_controller_kind: DaemonSet

# NGINX Ingress External LB IPs (for HAProxy/MetalLB)
nginx_ingress_external_ips:
{% for ip in ingress_external_ips %}
  - "{{ ip }}"
{% endfor %}

# NGINX Ingress Service
nginx_ingress_service_type: LoadBalancer
nginx_ingress_loadbalancer_ips:
{% for ip in ingress_external_ips %}
  - "{{ ip }}"
{% endfor %}

# NGINX Ingress Configuration
nginx_ingress_controller_config:
  use-forwarded-headers: "true"
  compute-full-forwarded-for: "true"
  use-proxy-protocol: "false"
  enable-real-ip: "true"
  real-ip-header: "X-Forwarded-For"
  real-ip-recursive: "true"
  proxy-body-size: "100m"
  client-max-body-size: "100m"
  ssl-redirect: "true"
  force-ssl-redirect: "true"
  hsts: "true"
  hsts-max-age: "31536000"
  hsts-include-subdomains: "true"

# NGINX Ingress TCP Services (for non-HTTP traffic)
nginx_ingress_tcp_services:
  # Example: expose Ceph RGW
  # "8080": "default/ceph-rgw:80"
  # "8443": "default/ceph-rgw:443"
  # "3306": "default/mysql:3306"
  # "5432": "default/postgresql:5432"

# NGINX Ingress UDP Services
nginx_ingress_udp_services:
  # "53": "kube-system/coredns:53"

# =============================================================================
# HAProxy Load Balancer Configuration (External LBs)
# =============================================================================
haproxy_enabled: true
haproxy_vip: "{{ haproxy_vip }}"
haproxy_vip_interface: "eth0"
haproxy_vip_cidr: "24"

# HAProxy Frontends
haproxy_frontends:
  kubernetes_api:
    bind: "{{ haproxy_vip }}:6443"
    mode: tcp
    default_backend: kubernetes_api_backend
    timeout_client: 30s
  monitoring:
    bind: "{{ haproxy_vip }}:9090"
    mode: http
    default_backend: monitoring_backend
    timeout_client: 30s

# HAProxy Backends
haproxy_backends:
  kubernetes_api_backend:
    balance: roundrobin
    mode: tcp
    servers:
{% for i in range(master_count) %}
      - "master-{{ i+1 }} {{ master_ips[i] }}:6443 check inter 2s fall 3 rise 2"
{% endfor %}
    timeout_server: 30s
  monitoring_backend:
    balance: roundrobin
    mode: http
    servers:
{% for i in range(worker_count) %}
      - "worker-{{ i+1 }} {{ worker_ips[i] }}:9090 check inter 5s fall 3 rise 2"
{% endfor %}
    timeout_server: 30s

# HAProxy Stats
haproxy_stats_port: 8404
haproxy_stats_user: admin
haproxy_stats_password: "{{ haproxy_stats_password }}"

# =============================================================================
# Keepalived Configuration (for HA VIP)
# =============================================================================
keepalived_enabled: true
keepalived_vip: "{{ haproxy_vip }}"
keepalived_interface: "eth0"
keepalived_virtual_router_id: 51
keepalived_priority:
  lb-01: 100
  lb-02: 90
  lb-03: 80
  lb-04: 70
keepalived_advert_int: 1
keepalived_auth_type: PASS
keepalived_auth_pass: "{{ keepalived_auth_password }}"

# =============================================================================
# Calico CNI Configuration
# =============================================================================
calico_ipip_mode: "{{ calico_ipip_mode }}"
calico_vxlan_mode: "{{ calico_vxlan_mode }}"
calico_ip_autodetection_method: "interface=eth0"
calico_node_liveness_check_enabled: true
calico_felix_ipinipmtu: 1440
calico_felix_vxlanmtu: 1450
calico_felix_vxlanport: 4789

# Calico BGP (if using BGP)
calico_bgp: false
calico_bgp_as_number: 65001
calico_bgp_peers: []
# Example:
# calico_bgp_peers:
#   - peer_ip: "10.0.0.1"
#     as_number: 65002

# =============================================================================
# DNS Configuration
# =============================================================================
internal_dns_servers:
{% for ip in dns_server_ips %}
  - "{{ ip }}"
{% endfor %}

search_domains:
  - "{{ cluster_name }}.{{ domain_suffix }}"
  - "{{ domain_suffix }}"

# =============================================================================
# Network CIDRs
# =============================================================================
node_cidr: "{{ node_cidr }}"
service_cidr: "{{ service_cidr }}"
pod_cidr: "{{ pod_cidr }}"
cluster_cidr: "{{ pod_cidr }}"

# =============================================================================
# Operations Servers
# =============================================================================
ops_linux_ip: "{{ ops_linux_ip }}"
ops_windows_ip: "{{ ops_windows_ip }}"