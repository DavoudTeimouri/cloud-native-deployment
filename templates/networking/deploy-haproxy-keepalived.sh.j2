#!/bin/bash
# Deploy HAProxy + Keepalived Script
# Generated by Wizard for {{ cluster_name }}
# LB IPs: {{ lb_ips }}
# Master IPs: {{ master_ips }}
# Worker IPs: {{ worker_ips }}

set -euo pipefail

# Configuration
LB_IPS=({{ lb_ips }})
MASTER_IPS=({{ master_ips }})
WORKER_IPS=({{ worker_ips }})
VIP="{{ haproxy_vip }}"
KEEPALIVED_AUTH_PASS="{{ keepalived_auth_password }}"
HAPROXY_STATS_USER="{{ haproxy_stats_user }}"
HAPROXY_STATS_PASS="{{ haproxy_stats_password }}"
CLUSTER_NAME="{{ cluster_name }}"
OPS_LINUX_IP="{{ ops_linux_ip }}"

# Function to deploy to a single LB
deploy_lb() {
    local lb_ip=$1
    local priority=$2
    
    echo "Deploying HAProxy + Keepalived to ${lb_ip} (priority: ${priority})..."
    
    # Install packages
    ssh ${OPS_LINUX_IP} "ssh ${lb_ip} 'apt-get update && apt-get install -y haproxy keepalived'"
    
    # Generate HAProxy config
    ssh ${OPS_LINUX_IP} "cat > /tmp/haproxy.cfg << 'EOF'
global:
  log /dev/log local0
  log /dev/log local1 notice
  chroot /var/lib/haproxy
  stats socket /run/haproxy/admin.sock mode 660 level admin
  stats timeout 30s
  user haproxy
  group haproxy
  daemon
  nbproc 1
  nbthread 4

defaults:
  log global
  mode tcp
  option tcplog
  option dontlognull
  timeout connect 5s
  timeout client 30s
  timeout server 30s

listen stats:
  bind *:8404
  mode http
  stats enable
  stats uri /stats
  stats refresh 10s
  stats auth ${HAPROXY_STATS_USER}:${HAPROXY_STATS_PASS}

frontend kubernetes_api:
  bind *:6443
  mode tcp
  option tcplog
  default_backend kubernetes_api_backend

backend kubernetes_api_backend:
  mode tcp
  balance roundrobin
  option tcp-check
EOF"
    
    # Add master servers
    for i in "${!MASTER_IPS[@]}"; do
        ssh ${OPS_LINUX_IP} "ssh ${lb_ip} 'echo \"  server master-$((i+1)) ${MASTER_IPS[i]}:6443 check inter 2s fall 3 rise 2\" >> /tmp/haproxy.cfg'"
    done
    
    ssh ${OPS_LINUX_IP} "ssh ${lb_ip} 'cat >> /tmp/haproxy.cfg << \"EOF\"

frontend monitoring_http:
  bind *:9090
  mode http
  option httplog
  default_backend monitoring_http_backend

backend monitoring_http_backend:
  mode http
  balance roundrobin
  option httpchk GET /api/health
EOF"
    
    for i in "${!WORKER_IPS[@]}"; do
        ssh ${OPS_LINUX_IP} "ssh ${lb_ip} 'echo \"  server worker-monitor-$((i+1)) ${WORKER_IPS[i]}:9090 check inter 5s fall 3 rise 2\" >> /tmp/haproxy.cfg'"
    done
    
    ssh ${OPS_LINUX_IP} "ssh ${lb_ip} 'cat >> /tmp/haproxy.cfg << \"EOF\"

frontend ingress_http:
  bind *:80
  mode http
  option httplog
  default_backend ingress_http_backend

backend ingress_http_backend:
  mode http
  balance roundrobin
EOF"
    
    for i in "${!WORKER_IPS[@]}"; do
        ssh ${OPS_LINUX_IP} "ssh ${lb_ip} 'echo \"  server ingress-worker-$((i+1)) ${WORKER_IPS[i]}:80 check inter 5s fall 3 rise 2\" >> /tmp/haproxy.cfg'"
    done
    
    # Copy config
    ssh ${OPS_LINUX_IP} "ssh ${lb_ip} 'cp /tmp/haproxy.cfg /etc/haproxy/haproxy.cfg && systemctl restart haproxy'"
    
    # Generate Keepalived config
    ssh ${OPS_LINUX_IP} "cat > /tmp/keepalived.conf << 'EOF'
global_defs {
  router_id ${CLUSTER_NAME}-ha
  vrrp_skip_check_adv_addr
  vrrp_garp_interval 0
  vrrp_garp_packet_loss_threshold 100
}

vrrp_instance VI_1 {
  state BACKUP
  interface eth0
  virtual_router_id 51
  priority ${priority}
  advert_int 1
  authentication {
    auth_type PASS
    auth_pass ${KEEPALIVED_AUTH_PASS}
  }
  virtual_ipaddress {
    ${VIP}/24
  }
}

vrrp_script check_haproxy {
  script "/usr/local/bin/check_haproxy.sh"
  interval 2
  weight 2
  fall 3
  rise 2
}

track_script {
  check_haproxy
}
EOF"
    
    # Copy keepalived config
    ssh ${OPS_LINUX_IP} "ssh ${lb_ip} 'cp /tmp/keepalived.conf /etc/keepalived/keepalived.conf'"
    
    # Create health check script
    ssh ${OPS_LINUX_IP} "cat > /tmp/check_haproxy.sh << 'EOF'
#!/bin/bash
if systemctl is-active --quiet haproxy; then
    exit 0
else
    exit 1
fi
EOF"
    
    ssh ${OPS_LINUX_IP} "ssh ${lb_ip} 'cp /tmp/check_haproxy.sh /usr/local/bin/check_haproxy.sh && chmod +x /usr/local/bin/check_haproxy.sh'"
    
    # Restart keepalived
    ssh ${OPS_LINUX_IP} "ssh ${lb_ip} 'systemctl restart keepalived && systemctl enable keepalived'"
}

# Deploy to all LBs
for i in "${!LB_IPS[@]}"; do
    # First LB gets highest priority
    if [ $i -eq 0 ]; then
        priority=100
    else
        priority=$((90 - i * 10))
    fi
    deploy_lb "${LB_IPS[i]}" $priority
done

echo "HAProxy + Keepalived deployment complete!"
echo "VIP ${VIP} should now be active on the primary LB"