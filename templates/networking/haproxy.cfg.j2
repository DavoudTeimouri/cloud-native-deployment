# Deploy HAProxy + Keepalived Template
# Generated by Wizard for {{ cluster_name }}
# LB IPs: {{ lb_ips }}

# HAProxy Configuration
# /etc/haproxy/haproxy.cfg

global:
  log /dev/log local0
  log /dev/log local1 notice
  chroot /var/lib/haproxy
  stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
  stats timeout 30s
  user haproxy
  group haproxy
  daemon
  nbproc 1
  nbthread 4
  cpu-map auto 0-3 0-3

defaults:
  log global
  mode tcp
  option tcplog
  option dontlognull
  timeout connect 5s
  timeout client 30s
  timeout server 30s
  errorfile 400 /etc/haproxy/errors/400.http
  errorfile 403 /etc/haproxy/errors/403.http
  errorfile 408 /etc/haproxy/errors/408.http
  errorfile 500 /etc/haproxy/errors/500.http
  errorfile 502 /etc/haproxy/errors/502.http
  errorfile 503 /etc/haproxy/errors/503.http
  errorfile 504 /etc/haproxy/errors/504.http

# Statistics
listen stats:
  bind {{ lb_ips[0] }}:8404
  mode http
  stats enable
  stats uri /stats
  stats refresh 10s
  stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_password }}

# Frontend: Kubernetes API Server
frontend kubernetes_api:
  bind {{ lb_ips[0] }}:6443
  mode tcp
  option tcplog
  default_backend kubernetes_api_backend

# Backend: Kubernetes API Servers
backend kubernetes_api_backend:
  mode tcp
  balance roundrobin
  option tcp-check
{% for i in range(master_count) %}
  server master-{{ i+1 }} {{ master_ips[i] }}:6443 check inter 2s fall 3 rise 2
{% endfor %}

# Frontend: Monitoring (Grafana)
frontend monitoring_http:
  bind {{ lb_ips[0] }}:9090
  mode http
  option httplog
  default_backend monitoring_http_backend

backend monitoring_http_backend:
  mode http
  balance roundrobin
  option httpchk GET /api/health
{% for i in range(worker_count) %}
  server worker-monitor-{{ i+1 }} {{ worker_ips[i] }}:9090 check inter 5s fall 3 rise 2
{% endfor %}

# Frontend: NGINX Ingress HTTP
frontend ingress_http:
  bind {{ lb_ips[0] }}:80
  mode http
  option httplog
  default_backend ingress_http_backend

backend ingress_http_backend:
  mode http
  balance roundrobin
{% for i in range(worker_count) %}
  server ingress-worker-{{ i+1 }} {{ worker_ips[i] }}:80 check inter 5s fall 3 rise 2
{% endfor %}