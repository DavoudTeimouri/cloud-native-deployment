# Keepalived Configuration Template
# Generated by Wizard for {{ cluster_name }}
# LB IPs: {{ lb_ips }}

# /etc/keepalived/keepalived.conf

global_defs {
  router_id {{ cluster_name }}-ha
  vrrp_skip_check_adv_addr
  vrrp_garp_interval 0
  vrrp_garp_packet_loss_threshold 100
}

# VRRP Instance for Kubernetes API
vrrp_instance VI_1 {
  state BACKUP
  interface eth0
  virtual_router_id {{ keepalived_router_id }}
  priority {{ keepalived_base_priority }}
  advert_int 1
  authentication {
    auth_type PASS
    auth_pass {{ keepalived_auth_password }}
  }
  virtual_ipaddress {
    {{ haproxy_vip }}/24
  }
}

# VRRP Script for health check
vrrp_script check_haproxy {
  script "/usr/local/bin/check_haproxy.sh"
  interval 2
  weight 2
  fall 3
  rise 2
}

# Track script
track_script {
  check_haproxy
}