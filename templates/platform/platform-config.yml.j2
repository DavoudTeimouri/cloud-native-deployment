# Platform Components Configuration Template
# Generated by Wizard for {{ cluster_name }}

# =============================================================================
# cert-manager Configuration
# =============================================================================
cert_manager_enabled: true
cert_manager_version: "v1.14.5"
cert_manager_namespace: cert-manager
cert_manager_email: "admin@{{ domain_suffix }}"
cert_manager_acme_server: "https://acme-v02.api.letsencrypt.org/directory"

# Issuer Configurations
cert_manager_issuers:
  # Self-signed issuer for internal certificates
  - name: selfsigned-issuer
    kind: ClusterIssuer
    self_signed: {}
  
  # CA issuer for internal PKI
  - name: ca-issuer
    kind: ClusterIssuer
    ca:
      secret_name: ca-key-pair

# Certificate Resources
cert_manager_certificates:
  # Wildcard certificate for internal domain
  - name: wildcard-internal
    namespace: cert-manager
    dns_names:
      - "*.{{ domain_suffix }}"
      - "{{ domain_suffix }}"
    issuer_ref:
      name: selfsigned-issuer
      kind: ClusterIssuer
    secret_name: wildcard-internal-tls
    duration: 8760h  # 1 year
    renew_before: 2160h  # 90 days

# =============================================================================
# Gatekeeper (OPA) Configuration
# =============================================================================
gatekeeper_enabled: true
gatekeeper_version: "v3.14.0"
gatekeeper_namespace: gatekeeper-system

# Gatekeeper Audit
gatekeeper_audit_interval: 60
gatekeeper_audit_from_cache: true
gatekeeper_emission_interval: 30
gatekeeper_enable_external_data: true

# Constraint Templates (common policies)
gatekeeper_constraint_templates:
  - k8srequiredlabels
  - k8suniquenesservice
  - k8spsphostfilesystem
  - k8spsphostnetworkingports
  - k8spsphostpid
  - k8spspprivilegedcontainer
  - k8spspproccapabilities
  - k8spspapparmor
  - k8spspseccomp
  - k8spspallowedusers
  - k8spspallowedusersgroups
  - k8spspfsGroup
  - k8spspvolumetypes

# Constraints
gatekeeper_constraints:
  - name: required-labels
    template: k8srequiredlabels
    match:
      kinds:
        - apiGroups: [""]
          kinds: ["Namespace"]
    parameters:
      labels:
        - "owner"
        - "environment"
        - "team"

# =============================================================================
# Rancher Configuration
# =============================================================================
rancher_enabled: true
rancher_version: "2.8.4"
rancher_namespace: cattle-system
rancher_hostname: "rancher.{{ domain_suffix }}"
rancher_bootstrap_password: "{{ rancher_bootstrap_password }}"
rancher_replicas: 3

# Rancher Ingress
rancher_ingress_class: nginx
rancher_tls_source: secret
rancher_tls_secret: rancher-tls

# Rancher Features
rancher_features:
  - "fleet=true"
  - "rke-machine-management=true"
  - "harvester=true"

# =============================================================================
# ArgoCD Configuration
# =============================================================================
argocd_enabled: true
argocd_version: "v2.10.5"
argocd_namespace: argocd
argocd_server_hostname: "argocd.{{ domain_suffix }}"
argocd_dex_hostname: "dex.{{ domain_suffix }}"
argocd_admin_password: "{{ argocd_admin_password }}"

# ArgoCD RBAC
argocd_rbac_policy: |
  g, argocd-admins, role:admin
  g, argocd-developers, role:admin

# ArgoCD Projects
argocd_projects:
  - name: infrastructure
    description: "Infrastructure components"
    source_repos:
      - "*"
    destinations:
      - namespace: "*"
        server: "*"
    cluster_resource_whitelist:
      - group: ""
        kind: "Namespace"
      - group: "rbac.authorization.k8s.io"
        kind: "ClusterRole"
      - group: "rbac.authorization.k8s.io"
        kind: "ClusterRoleBinding"
  - name: applications
    description: "Application workloads"
    source_repos:
      - "*"
    destinations:
      - namespace: "*"
        server: "*"

# ArgoCD Repositories (GitOps)
argocd_repositories:
  - name: infra-repo
    url: "https://gitlab.{{ domain_suffix }}/infra/k8s-manifests.git"
    type: git
    username: "{{ gitlab_username }}"
    password: "{{ gitlab_token }}"
  - name: helm-charts
    url: "https://gitlab.{{ domain_suffix }}/infra/helm-values.git"
    type: git
    username: "{{ gitlab_username }}"
    password: "{{ gitlab_token }}"

# ArgoCD Applications
argocd_applications:
  - name: cert-manager
    project: infrastructure
    source:
      repoURL: "https://gitlab.{{ domain_suffix }}/infra/helm-values.git"
      targetRevision: HEAD
      path: cert-manager
      helm:
        valueFiles:
          - values.yaml
    destination:
      server: https://kubernetes.default.svc
      namespace: cert-manager
    syncPolicy:
      automated:
        prune: true
        selfHeal: true

# =============================================================================
# Operations Servers
# =============================================================================
ops_linux_ip: "{{ ops_linux_ip }}"
ops_windows_ip: "{{ ops_windows_ip }}"