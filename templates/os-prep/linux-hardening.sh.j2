#!/bin/bash
# OS Preparation Script Template - Generated by Wizard
# Customized for {{ cluster_name }}

set -euo pipefail

# Configuration from wizard
CLUSTER_NAME="{{ cluster_name }}"
DOMAIN_SUFFIX="{{ domain_suffix }}"
NTP_SERVERS="{% for ip in dns_server_ips %}{{ ip }}{% if not loop.last %} {% endif %}{% endfor %}"
DNS_SERVERS="{{ ntp_servers }}"
SEARCH_DOMAINS="{{ cluster_name }}.{{ domain_suffix }} {{ domain_suffix }}"

# Node IPs
MASTER_IPS=({{ master_ips }})
WORKER_IPS=({{ worker_ips }})
LB_IPS=({{ lb_ips }})
MON_IPS=({{ ceph_mon_ips }})
OSD_IPS=({{ ceph_osd_ips }})
RGW_IP="{{ rgw_host_ip }}"
NEXUS_IP="{{ nexus_host_ip }}"
HARBOR_IP="{{ harbor_host_ip }}"

# Network configuration
NODE_CIDR="{{ node_cidr }}"
SERVICE_CIDR="{{ service_cidr }}"
POD_CIDR="{{ pod_cidr }}"

# Storage configuration
CEPHFS_STORAGE_CLASS="{{ cephfs_storage_class }}"
RBD_STORAGE_CLASS="{{ rbd_storage_class }}"

# ======================================================================
# OS Preparation Functions
# ======================================================================

configure_ntp() {
    echo "Configuring NTP servers: $NTP_SERVERS"
    
    # Install chrony
    apt-get update
    apt-get install -y chrony
    
    # Configure chrony
    cat > /etc/chrony/chrony.conf << EOF
pool $NTP_SERVERS iburst
driftfile /var/lib/chrony/drift
makestep 1 3
rtcsync
keyfile /etc/chrony/chrony.keys
leapsectz right/UTC
logdir /var/log/chrony
EOF
    
    systemctl restart chrony
    systemctl enable chrony
}

configure_dns() {
    echo "Configuring DNS servers: $DNS_SERVERS"
    echo "Search domains: $SEARCH_DOMAINS"
    
    # Configure resolv.conf
    cat > /etc/resolv.conf << EOF
{% for ip in dns_server_ips %}
nameserver {{ ip }}
{% endfor %}
search {% for d in search_domains %} {{ d }}{% endfor %}
options timeout:2 attempts:3
EOF
}

harden_os() {
    echo "Applying OS hardening for cluster: $CLUSTER_NAME"
    
    # Kernel parameters
    cat >> /etc/sysctl.conf << EOF
net.core.somaxconn = 65535
net.ipv4.tcp_max_syn_backlog = 65535
net.ipv4.ip_forward = 1
vm.max_map_count = 262144
EOF
    
    sysctl -p
    
    # Disable swap
    swapoff -a
    sed -i '/ swap / s/^\(.*\)$/#\1/' /etc/fstab
    
    # Configure firewall
    ufw allow ssh
    ufw allow 6443/tcp    # Kubernetes API
    ufw allow 2379:2380/tcp # etcd
    ufw allow 10250:10259/tcp # kubelet
    ufw allow 30000:32767/tcp # NodePort
    ufw allow 80/tcp      # HTTP
    ufw allow 443/tcp     # HTTPS
    ufw allow 8472/udp    # Flannel VXLAN
    ufw enable
}

install_prerequisites() {
    echo "Installing prerequisites..."
    apt-get update
    apt-get install -y curl wget apt-transport-https ca-certificates gnupg lsb-release software-properties-common
}

# ======================================================================
# Main
# ======================================================================

install_prerequisites
configure_ntp
configure_dns
harden_os

echo "OS preparation complete for cluster: $CLUSTER_NAME"