#!/bin/bash
# OS Preparation Script - Generated by Wizard
# Customized for cluster: {{ cluster_name }}
# NTP Servers: {{ env.NTP_SERVERS }}
# DNS Servers: {{ env.DNS_SERVERS }}
# Search Domains: {{ env.SEARCH_DOMAINS }}

set -euo pipefail

# Wizard-provided variables (passed as environment variables)
NTP_SERVERS=(${NTP_SERVERS[@]})
DNS_SERVERS=(${DNS_SERVERS[@]})
SEARCH_DOMAINS=(${SEARCH_DOMAINS[@]})

# Script variables
DEPLOY_USER="deploy"
DEPLOY_USER_SSH_KEY="${DEPLOY_USER_SSH_KEY:-}"
NEXUS_URL="${NEXUS_URL:-}"

# ============================================================================
# Functions
# ============================================================================

log() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] $*"
}

error() {
    log "ERROR: $*" >&2
}

# ============================================================================
# Main Script
# ============================================================================

main() {
    log "Starting OS preparation for $(hostname)"
    
    # 1. Configure kernel parameters for Kubernetes
    configure_kernel_parameters
    
    # 2. Ensure required kernel modules are loaded
    configure_kernel_modules
    
    # 3. Disable swap
    disable_swap
    
    # 4. Configure package repositories (Nexus mirror if provided)
    configure_package_repositories
    
    # 5. Install essential packages
    install_essential_packages
    
    # 6. Install and configure containerd
    install_containerd
    
    # 7. Setup deploy user
    setup_deploy_user
    
    # 8. Harden SSH
    harden_ssh
    
    # Configure NTP
    # Example: 
    # Note: 
    ###  this script would continue with the full OS hardening steps...
    # For brevity in this example, we're setting uses the user-provided values.
    
    # 9. Configure NTP (Chrony) with user-provided servers
    configure_ntp
    
    # 10. Configure DNS with user-provided servers and search domains
    configure_dns
    
    # 11. Configure security limits
    configure_security_limits
    
    # 12. Configure auditd
    configure_auditd
    
    # 13. Disable unnecessary services
    disable_unnecessary_services
    
    # 14. Remove unnecessary packages
    remove_unnecessary_packages
    
    log "OS preparation completed successfully"
}

# ============================================================================
# Function Definitions
# ============================================================================

configure_kernel_parameters() {
    log "Configuring kernel parameters"
    local sysctl_params=(
        "net.ipv4.ip_forward=1"
        "net.bridge.bridge-nf-call-iptables=1"
        "net.bridge.bridge-nf-call-ip6tables=1"
        "net.ipv4.tcp_keepalive_time=600"
        "net.ipv4.tcp_keepalive_intvl=30"
        "net.ipv4.tcp_keepalive_probes=10"
        "net.core.somaxconn=65535"
        "net.ipv4.tcp_max_syn_backlog=65535"
        "vm.max_map_count=262144"
        "vm.swappiness=0"
        "fs.inotify.max_user_watches=524288"
        "fs.inotify.max_user_instances=8192"
        "fs.file-max=2097152"
        "kernel.pid_max=4194303"
    )
    
    for param in "${sysctl_params[@]}"; do
        key="${param%%=*}"
        value="${param#*=}"
        # Using sysctl to set parameter
        sysctl -w "$key=$value" >/dev/null
        # Also make it persistent
        if ! grep -q "^$key" /etc/sysctl.conf 2>/dev/null; then
            echo "$key = $value" >> /etc/sysctl.conf
        fi
    done
    sysctl -p /etc/sysctl.conf >/dev/null
}

configure_kernel_modules() {
    log "Loading required kernel modules"
    local modules=("br_netfilter" "overlay" "ip_vs" "ip_vs_rr" "ip_vs_wrr" "ip_vs_sh" "nf_conntrack")
    
    for module in "${modules[@]}"; do
        if ! lsmod | grep -q "^$module"; then
            modprobe "$module"
            # Make it persistent
            echo "$module" >> /etc/modules-load.d/k8s.conf
        fi
    done
}

disable_swap() {
    log "Disabling swap"
    swapoff -a
    # Comment out any swap lines in fstab
    sed -i '/\sswap\s/s/^/#&/' /etc/fstab
}

configure_package_repositories() {
    log "Configuring package repositories"
    if [[ -n "$NEXUS_URL" ]]; then
        log "Using Nexus repository at $NEXUS_URL"
        # Create Nexus sources.list
        cat > /etc/apt/sources.list.d/nexus.list <<EOF
deb http://$NEXUS_URL/repository/apt-ubuntu-hosted/ $(lsb_release -cs) main restricted universe multiverse
deb http://$NEXUS_URL/repository/apt-ubuntu-hosted/ $(lsb_release -cs)-updates main restricted universe multiverse
deb http://$NEXUS_URL/repository/apt-ubuntu-hosted/ $(lsb_release -cs)-security main restricted universe multiverse
EOF
        # Remove or comment out the default sources.list
        > /etc/apt/sources.list
        apt-get update
    else
        log "Using default Ubuntu repositories"
    fi
}

install_essential_packages() {
    log "Installing essential packages"
    apt-get update
    apt-get install -y \
        apt-transport-https \
        ca-certificates \
        curl \
        gnupg \
        lsb-release \
        socat \
        conntrack \
        ipset \
        jq \
        chrony \
        auditd \
        apparmor \
        apparmor-utils \
        ceph-common \
        rsync \
        net-tools \
        tcpdump \
        strace
}

install_containerd() {
    log "Installing containerd"
    # In a real script, we would install a specific version from Nexus
    # For this example, we'll install from the repo but note that in air-gap
    # you would use the Nexus mirror
    apt-get install -y containerd
    
    # Configure containerd
    mkdir -p /etc/containerd
    containerd config default > /etc/containerd/config.toml
    
    # Set systemd cgroup
    sed -i 'sers st" | sed -i 's/SystemdCgroup \= false/SystemdCgroup \= true/' /etc/containerd/config.toml
    
    # Configure containerd mirrors for Harbor (if provided)
    if [[ -n "$HARBOR_URL" ]]; then
        log "Configuring containerd to use Harbor mirror: $HARBOR_URL"
        cat >> /etc/containerd/config.toml <<EOF

[plugins."io.containerd.grpc.v1.cri".registry.mirrors]
  [plugins."io.containerd.grpc.v1.cri".registry.mirrors."$HARBOR_URL"]
    endpoint = ["https://$HARBOR_URL"]
[plugins."io.containerd.grpc.v1.cri".registry.configs."$HARBOR_URL".tls]
  insecure_skip_verify = true
EOF
    fi
    
    systemctl daemon-reload
    systemctl enable --now containerd
}

setup_deploy_user() {
    log "Setting up deploy user"
    # Create deploy user if it doesn't exist
    if ! id "$DEPLOY_USER" &>/dev/null; then
        useradd -m -s /bin/bash -G sudo,docker "$DEPLOY_USER"
        log "Created user: $DEPLOY_USER"
    fi
    
    # Setup SSH key if provided
    if [[ -n "$DEPLOY_USER_SSH_KEY" ]]; then
        mkdir -p /home/$DEPLOY_USER/.ssh
        echo "$DEPLOY_USER_SSH_KEY" > /home/$DEPLOY_USER/.ssh/authorized_keys
        chown -R $DEPLOY_USER:$DEPLOY_USER /home/$DEPLOY_USER/.ssh
        chmod 700 /home/$DEPLOY_USER/.ssh
        chmod 600 /home/$DEPLOY_USER/.ssh/authorized_keys
        log "SSH key installed for $DEPLOY_USER"
    fi
    
    # Passwordless sudo for deploy user
    echo "$DEPLOY_USER ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/$DEPLOY_USER
    chmod 440 /etc/sudoers.d/$DEPLOY_USER
}

harden_ssh() {
    log "Hardening SSH configuration"
    # Backup original sshd_config
    cp /etc/ssh/sshd_config /etc/ssh/sshd_config.bak
    
    # Apply hardening settings
    sed -i 's/^#\?PermitRootLogin .*/PermitRootLogin no/' /etc/ssh/sshd_config
    sed -i 's/^#\?PasswordAuthentication .*/PasswordAuthentication no/' /etc/ssh/sshd_config
    sed -i 's/^#\?X11Forwarding .*/X11Forwarding no/' /etc/ssh/sshd_config
    sed -i 's/^#\?MaxAuthTries .*/MaxAuthTries 3/' /etc/ssh/sshd_config
    sed -i 's/^#\?ClientAliveInterval .*/ClientAliveInterval 300/' /etc/ssh/sshd_config
    sed -i 's/^#\?ClientAliveCountMax .*/ClientAliveCountMax 2/' /etc/ssh/sshd_config
    sed -i 's/^#\?PermitEmptyPasswords .*/PermitEmptyPasswords no/' /etc/ssh/sshd_config
    sed -i 's/^#\?ChallengeResponseAuthentication .*/ChallengeResponseAuthentication no/' /etc/ssh/sshd_config
    sed -i 's/^#\?UsePAM .*/UsePAM yes/' /etc/ssh/sshd_config
    
    systemctl restart sshd
}

configure_ntp() {
    log "Configuring NTP (Chrony) with user-provided servers"
    # Backup original config
    cp /etc/chrony/chrony.conf /etc/chrony/chrony.conf.bak
    
    # Create new config with user-provided NTP servers
    cat > /etc/chrony/chrony.conf <<EOF
# NTP configuration for $(hostname)
# NTP Servers provided by user: ${NTP_SERVERS[*]}
$(for server in "${NTP_SERVERS[@]}"; do echo "server $server iburst"; done)
driftfile /var/lib/chrony/drift
makestep 1.0 3
rtcsync
logdir /var/log/chrony
maxupdateskew 100.0
bindcmdaddress 127.0.0.1
# Allow local network to query this NTP server (adjust as needed)
allow 10.0.0.0/8
local stratum 10
EOF
    
    systemctl enable --now chrony
    # Wait for sync
    log "Waiting for NTP synchronization..."
    sleep 5
    chronyc tracking || true
}

configure_dns() {
    log "Configuring DNS with user-provided servers and search domains"
    # Backup original resolv.conf
    cp /etc/resolv.conf /etc/resolv.conf.bak
    
    # Create new resolv.conf
    > /etc/resolv.conf
    for server in "${DNS_SERVERS[@]}"; do
        echo "nameserver $server" >> /etc/resolv.conf
    done
    for domain in "${SEARCH_DOMAINS[@]}"; do
        echo "search $domain" >> /etc/resolv.conf
    done
    
    # Make it immutable to prevent overwriting by dhcpcd or NetworkManager
    chattr +i /etc/resolv.conf
}

configure_security_limits() {
    log "Configuring security limits"
    cat > /etc/security/limits.d/99-k8s.conf <<EOF
* soft nofile 655360
* hard nofile 655360
* soft nproc 655360
* hard nproc 655360
* soft memlock unlimited
* hard memlock unlimited
root soft nofile 655360
root hard nofile 655360
EOF
}

configure_auditd() {
    log "Configuring auditd"
    cat > /etc/audit/rules.d/k8s-audit.rules <<EOF
# Audit rules for Kubernetes
-w /etc/kubernetes/ -p wa -k k8s-config
-w /var/lib/etcd/ -p wa -k etcd-data
-w /etc/ssh/sshd_config -p wa -k ssh-config
-w /etc/passwd -p wa -k identity
-w /etc/sudoers -p wa -k sudoers
-w /etc/sudoers.d/ -p wa -k sudoers
-w /var/log/ -p wa -k logs
-a always,exit -F arch=b64 -S mount -S umount -S umount2 -k mount
-a always,exit -F arch=b64 -S setuid -S setgid -S setreuid -S setregid -S setresuid -S setresgid -k id-change
EOF
    systemctl restart auditd
}

disable_unnecessary_services() {
    log "Disabling unnecessary services"
    local services=("ufw" "snapd" "ModemManager" "avahi-daemon")
    for service in "${services[@]}"; do
        systemctl disable --now "$service" 2>/dev/null || true
    done
}

remove_unnecessary_packages() {
    log "Removing unnecessary packages"
    apt-get purge -y snapd cloud-init 2>/dev/null || true
    apt-get autoremove -y
    apt-get autoclean -y
}

# Execute main function
main "$@"